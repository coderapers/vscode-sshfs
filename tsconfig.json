{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": ["ES2020"],
        "sourceMap": true,
        "rootDir": ".",
        "baseUrl": ".",
        "outDir": "out",
        "strict": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "paths": {
            "common/*": ["./common/*"]
        },
        "types": ["node", "vscode"]
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "out"
    ]
}
