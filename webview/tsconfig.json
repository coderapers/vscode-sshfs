{
    "compilerOptions": {
        "outDir": "../out/webview",
        "sourceMap": true,
        "noImplicitAny": false,
        "module": "ESNext",
        "target": "ES2020",
        "jsx": "react-jsx",
        "moduleResolution": "node",
        "baseUrl": ".",
        "paths": {
            "common/*": ["../common/*"]
        },
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*", "../common/**/*"]
}
